<section class="hero is-medium" id="hero">
  <div class="hero-body">
    <div class="container">
      <figure class="image is-128x128 mb-5">
        <%= image_tag "ronald.jpg", class: "is-rounded", alt: "Ronald Langeveld", style: "object-fit: cover; object-position: top; width: 128px; height: 128px;" %>
      </figure>
      <h1 class="title is-1 mb-4">
        I ship from week one.
      </h1>
      <p class="subtitle is-4 has-text-weight-normal mb-4">
        Production code in your first sprint. Senior judgment on architecture and systems from the same week. Month to month, stay as long as it's worth it.
      </p>
      <p class="is-size-5 has-text-grey-dark mb-5" style="max-width: 680px;">
        I'm Ronald, a fractional principal engineer based in <strong>South Korea</strong>. I plug into your team, write production code, and take on architecture and systems work as it comes up. Clean exit when you're done.
      </p>

      <div class="mb-6">
        <a href="https://calendar.app.google/qGDs2ijrYeASVriL6" target="_blank" rel="noopener" class="button is-dark is-medium">
          Book an intro call
        </a>
      </div>

      <div class="columns is-mobile is-multiline is-vcentered mt-4">
        <% logos.each do |logo| %>
          <div class="column is-narrow py-3 pr-5">
            <%= image_tag logo[:src], alt: logo[:alt], class: "brand-logo", width: 120, height: 40 %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>
